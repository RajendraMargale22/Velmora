<% layout("/layouts/boilerplate") %>

<!-- HERO -->
<section class="hero position-relative d-flex align-items-center justify-content-center text-center mt-2">

    <!-- Image with fallback -->
    <img 
        src="https://images.pexels.com/photos/753626/pexels-photo-753626.jpeg" 
        onerror="this.onerror=null; this.src='https://images.unsplash.com/photo-1501785888041-af3ef285b470';"
        class="hero-img"
    >

    <!-- Overlay Content -->
    <div class="hero-content position-absolute">
        <h1 class="fw-bold text-white">Find your next stay</h1>
        <p class="text-white">Explore unique places to stay around the world</p>

        <div class="search-box mt-4 d-flex justify-content-center">
            <input type="text" placeholder="Search destinations" class="form-control search-input">
            <button class="btn btn-danger ms-2">Search</button>
        </div>
    </div>

</section>

<!-- CATEGORIES -->
<section class="container mt-5">
    <h4 class="mb-4">Browse by Category</h4>

    <div class="row text-center g-4">
        <div class="col-md-3">
            <div class="category-card">
                <i class="fa-solid fa-umbrella-beach"></i>
                <p>Beach</p>
            </div>
        </div>

        <div class="col-md-3">
            <div class="category-card">
                <i class="fa-solid fa-mountain"></i>
                <p>Mountains</p>
            </div>
        </div>

        <div class="col-md-3">
            <div class="category-card">
                <i class="fa-solid fa-city"></i>
                <p>City</p>
            </div>
        </div>

        <div class="col-md-3">
            <div class="category-card">
                <i class="fa-solid fa-tree"></i>
                <p>Nature</p>
            </div>
        </div>
    </div>
</section>

<!-- FEATURED LISTINGS -->
<section class="container mt-5">
    <h4 class="mb-4">Featured Stays</h4>

    <div class="row g-4">
        <% for(let listing of listings){ %>
            <div class="col-md-4">
                <a href="/listings/<%= listing._id %>" class="listing-link">
                    <div class="card home-card">
                        <img src="<%= listing.image.url %>" class="card-img-top">
                        <div class="card-body ms-2">
                            <h6><%= listing.title %></h6>
                            <p class="text-muted">
                                <%= listing.location %>, <%= listing.country %>
                            </p>
                        </div>
                    </div>
                </a>
            </div>
        <% } %>
    </div>
</section>

<!-- Why Choose Velmora -->
<section class="container mt-5 text-center">
    <h4 class="mb-4">Why Choose Velmora</h4>

    <div class="row g-4">

        <div class="col-md-4">
            <i class="fa-solid fa-star fa-2x text-danger"></i>
            <h6 class="mt-2">Top Rated</h6>
            <p class="text-muted">Best quality stays curated for you</p>
        </div>

        <div class="col-md-4">
            <i class="fa-solid fa-lock fa-2x text-danger"></i>
            <h6 class="mt-2">Secure Booking</h6>
            <p class="text-muted">Safe and trusted booking experience</p>
        </div>

        <div class="col-md-4">
            <i class="fa-solid fa-headset fa-2x text-danger"></i>
            <h6 class="mt-2">24/7 Support</h6>
            <p class="text-muted">We are always here to help you</p>
        </div>

    </div>
</section>

<!-- Travel Inspiration -->
<section class="container mt-5">
    <h4 class="mb-4">Travel Inspiration</h4>

    <div class="row g-4">

        <div class="col-md-6">
            <div class="inspire-card">
                <img src="https://images.pexels.com/photos/1365425/pexels-photo-1365425.jpeg" alt="Mountain image" />
                <div class="overlay-text">Explore Mountains</div>
            </div>
        </div>

        <div class="col-md-6">
            <div class="inspire-card">
                <img src="https://images.pexels.com/photos/4612299/pexels-photo-4612299.jpeg" alt="Beach image" />
                <div class="overlay-text">Beach Escapes</div>
            </div>
        </div>

        <div class="col-md-6">
            <div class="inspire-card">
                <img src="https://images.pexels.com/photos/3155724/pexels-photo-3155724.jpeg" alt="Island image" />
                <div class="overlay-text">Islands Beauty</div>
            </div>
        </div>

        <div class="col-md-6">
            <div class="inspire-card">
                <img src="https://images.pexels.com/photos/35882705/pexels-photo-35882705.jpeg" alt="Desert image" />
                <div class="overlay-text">Deserts Rides</div>
            </div>
        </div>

    </div>
</section>

<!-- CTA -->
<section class="cta text-center mt-5 p-5">
    <h4>Ready to explore?</h4>
    <a href="/listings" class="btn btn-dark mt-3">Start Browsing</a>
</section>