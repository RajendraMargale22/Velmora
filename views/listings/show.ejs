<% layout("/layouts/boilerplate") %>

<script>
    const mapToken = "<%= mapToken %>";
    const listing = <%- JSON.stringify(listing) %>;
</script>
    
    <!-- Selected Listing Details -->
    <div class="row mt-3 mb-3">
        <div class="col-8 offset-3">
            <h3> <%= listing.title %> </h3>
        </div>

        <div class="card col-6 offset-3 mt-3 show-card listing-card" >
            <img src="<%= listing.image.url %>" class="card-img-top show-img" alt="listing-image of <%= listing.title %>">
            <div class="card-body">
                <!-- <p class="card-text mt-3 showCard-title"><b><%= listing.title %></b></p> -->
                 <p class="card-text mt-3"> <i>Owned by <%= listing.owner.username %> </i></p>
                <p class="card-text"><%= listing.description %></p>
                <p class="card-text"><%= listing.location %> , <%= listing.country %></p>
                <p class="card-text"> &#8377; <%= listing.price.toLocaleString("en-IN") %></p>    
            </div>
        </div>
    
        <% if(currUser && currUser._id.equals(listing.owner._id)) {  %> 

        <div class="col-6 offset-3 show-btns mt-3 mb-4">

            <form action="/listings/<%= listing._id %>/edit">
                <button class="btn btn-outline-dark show-btn">Edit</button>
            </form>

            <form action="/listings/<%= listing._id %>?_method=DELETE" method="POST">
                <button class="btn btn-dark show-btn">Delete</button>
            </form>

        </div>
        <% } %> 
        

        <!-- Leave a Review -->
        <div class="col-8 offset-3 mb-3 mt-3">
            <hr/>
            <% if(currUser){ %>
            <h4>Leave a Review</h4>

            <form action="/listings/<%= listing._id %>/reviews" method="post" novalidate class="needs-validation">

                <div class="mb-3 mt-3">
                    <label class="form-label">Rating</label>
                    <div class="star-rating" >
                        <i class="fa-solid fa-star star" data-value="1"></i>
                        <i class="fa-solid fa-star star" data-value="2"></i>
                        <i class="fa-solid fa-star star" data-value="3"></i>
                        <i class="fa-solid fa-star star" data-value="4"></i>
                        <i class="fa-solid fa-star star" data-value="5"></i>
                    </div>
                    <input type="hidden" name="review[rating]" id="rating-value">
                    <div class="invalid-feedback" style="display:none;">Rate your Experience!</div>
                </div>

                <div class="mb-3">
                    <label for="comment" class="form-label">Comment</label>
                    <textarea name="review[comment]" id="comment" cols="20" rows="5" class="form-control" required></textarea>
                    <div class="invalid-feedback">Please provide a Review</div>
                </div>

                <button class="btn btn-outline-dark mt-3">Submit</button>

            </form>
            <% } %>


            <!-- All Reviews -->
            <% if(listing.reviews.length > 0) { %>
            <p class="mt-3"><b>All Reviews</b></p>

            <div class="row">
                <% for(review of listing.reviews) { %>
                    <div class="card col-5 ms-3 mb-3">
                        <div class="card-body">
                            <h5 class="card-title mt-2">@<%= review.author.username %></h5>

                            <p class="card-text review-stars mb-3">
                                <% for(let i = 1; i <= 5; i++) { %>
                                    <% if(i <= review.rating) { %>
                                        <i class="fa-solid fa-star review-star-filled"></i>
                                    <% } else { %>
                                        <i class="fa-regular fa-star review-star-empty"></i>
                                    <% } %>
                                <% } %>
                            </p>

                            <p class="card-text"><%= review.comment %></p>

                            <% if(currUser && currUser._id.equals(review.author._id)) {  %> 
                            <form action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE" method="post" class="mb-3">
                                <button class="btn btn-sm btn-dark">Delete</button>
                            </form>
                            <% } %>
                        </div>
                    </div>
                <% } %>
            </div>
            <% } %>

            <br><br>

            <!-- Map -->
            <div class="">
                <h3>Where you'll be</h3>
                <div id="map"></div>
            </div>

        </div>

    </div>

    <script src="/js/map.js"></script>


    


    


    

